# TokenNest 环境变量覆盖（可选）
# 复制为 .env 后填值即可覆盖 config/tokennest.yaml

# Server
TN_HOST=0.0.0.0
TN_PORT=8787

# Polling
TN_POLL_CHATGPT_SEC=60
TN_POLL_MINIMAX_SEC=60
TN_REQUEST_TIMEOUT_SEC=15

# Paths
TN_CACHE_DIR=./cache
TN_CODEX_AUTH_FILE=~/.codex/auth.json
TN_MINIMAX_CONFIG=./config/minimax.json

# Stale threshold (sec) — 缓存超过这个时间算 stale，写到 warningText
TN_STALE_THRESHOLD_SEC=300
