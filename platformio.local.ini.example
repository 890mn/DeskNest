; DeskNest - platformio.local.ini.example
; 栖屏 DeskNest — 本机个人配置模板（入库，复制为 platformio.local.ini 后填入）
;
; 为什么有这个文件：SSID/密码/TokenNest URL/设备 token 是个人凭证或家庭网络环境,
; 不应该 commit 到 git。PIO 支持 platformio.local.ini 这样的"按机器配置"
; 文件自动从 .example 复制。
;
; 第一次跑 pio run 时,scripts/pio_local_config.py 钩子会检查
; platformio.local.ini 是否存在:不存在则从本 example 复制一份并打印警告。
;
; 文件格式:
;   [secrets] section 由 pio_local_config.py 用 configparser 读取。
;   值原样写入,无需引号包裹 —— SCons 会在注入编译器时负责 shell 转义,
;
; 留空表示"未配置":src/config.h 里的 #ifndef 默认值生效 (空字符串),
; 固件 graceful 降级到 NVS Config Portal / 演示数据。

[secrets]
; K10 要连的 WiFi
wifi_ssid     = YOUR_WIFI_SSID
wifi_pass     = YOUR_WIFI_PASSWORD
; TokenNest HTTP 桥接 URL:K10 通过 LAN 拉这个地址
; 端口 = TokenNest 默认 8787
; 用 127.0.0.1 不行 (K10 不在本机);要填本机 LAN IP
tokennest_url = http://YOUR_LAN_IP:8787/status.json
