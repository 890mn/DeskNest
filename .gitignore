.pio
# PIO 从 .ino 自动生成的中间产物，不入库
DeskNest.ino.cpp
# .vscode is machine-local editor state — keep out of VCS
.vscode/
__pycache__/
*.pyc

# Machine-local Claude permissions — keep out of VCS
.claude/*

# Development markdown — keep out of VCS
# (README.md is the public project readme and stays tracked.)
new.md
# Keep ordinary new docs local. HALF-Work control artifacts are local-only in
# the personal pilot; the UI mockup remains a versioned acceptance artifact.
docs/
!/docs/
docs/*
!docs/ui-mockup/
!docs/ui-mockup/index.html
!docs/USER_GUIDE.md
!docs/ARCHITECTURE.md
!docs/V1_RELEASE_CHECKLIST.md
!docs/IMAGE_PROMPTS.md
!docs/DeskNest.png
!docs/structure.png
docs/control/

# HALF-Work control/task artifacts and local runtime files
.tasks/
.codex/
*.local.md

pc-simulator

# TokenNest 本地端 AI 用量聚合服务（Node.js 子项目）
# 见 TokenNest/README.md
TokenNest/node_modules/
TokenNest/cache/
TokenNest/logs/
TokenNest/tmp/
# 真值配置文件不入库（example 入库）
TokenNest/config/tokennest.yaml
TokenNest/config/minimax.json
TokenNest/.env
!TokenNest/docs/
TokenNest/docs/*
!TokenNest/docs/STARTUP.md
!TokenNest/docs/WIRE_FORMAT.md

# DeskNest 个人凭证配置（WiFi SSID/密码、TokenNest URL）
# 复制 platformio.local.ini.example 为 platformio.local.ini 后填入
# scripts/pio_local_config.py 会在首次 pio run 时自动 copy 并提示
platformio.local.ini
# pre-script 从 platformio.local.ini [secrets] 生成此目录
include/generated/

# CNFontNest local generated manifests and cache
.cnfontnest/
